<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <!-- Add foreign key from books to authors -->
    <changeSet id="add_foreign_key_from_book_to_author" author="lesnik">
        <addForeignKeyConstraint baseColumnNames="author" baseTableName="books"
                                 constraintName="fk_book_author_id"
                                 referencedColumnNames="author_id" referencedTableName="authors"/>
    </changeSet>

</databaseChangeLog>
