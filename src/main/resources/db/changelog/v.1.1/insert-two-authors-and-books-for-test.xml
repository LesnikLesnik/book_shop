<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <!-- ChangeSet to insert Author: Федор Достоевский -->
    <changeSet id="insert_author_dostoevsky" author="lesnik">
        <insert tableName="authors">
            <column name="author_id" value="1"/>
            <column name="first_name" value="Федор"/>
            <column name="last_name" value="Достоевский"/>
        </insert>
    </changeSet>

    <!-- ChangeSet to insert Author: Николо Макиавелли -->
    <changeSet id="insert_author_machiavelli" author="lesnik">
        <insert tableName="authors">
            <column name="author_id" value="2"/>
            <column name="first_name" value="Николо"/>
            <column name="last_name" value="Макиавелли"/>
        </insert>
    </changeSet>

</databaseChangeLog>
